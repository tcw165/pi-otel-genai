{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "experimentalDecorators": true,
    "paths": {
      "@this/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
