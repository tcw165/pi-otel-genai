{
  "name": "@oh-my-goose/pi-otel-genai",
  "version": "0.1.3",
  "description": "OpenTelemetry that follows GenAI protocol, that is compatible with many observability platform like Braintrust",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oh-my-goose/pi-otel-genai.git"
  },
  "homepage": "https://github.com/oh-my-goose/pi-otel-genai#readme",
  "bugs": {
    "url": "https://github.com/oh-my-goose/pi-otel-genai/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "pi-package",
    "pi-extension",
    "opentelemetry",
    "otel",
    "telemetry",
    "genai",
    "braintrust",
    "tracing"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "bazel test //...",
    "typecheck": "tsc --noEmit",
    "release:check": "bazel test //... && just dist && npm pack --dry-run",
    "prepublishOnly": "npm run release:check"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.53.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.18"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "koffi", "protobufjs", "unrs-resolver"]
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.212.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/resources": "^2.5.1",
    "@opentelemetry/sdk-metrics": "^2.5.1",
    "@opentelemetry/sdk-trace-base": "^2.5.1",
    "@opentelemetry/semantic-conventions": "^1.39.0"
  }
}
